<div class="bg-white rounded-lg shadow-md p-6">
    <% if (locals.message) { %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6" role="alert">
            <i class="fas fa-check-circle mr-2"></i>
            <span class="block sm:inline"><%= message %></span>
        </div>
    <% } %>

    <% if (locals.error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
            <i class="fas fa-exclamation-circle mr-2"></i>
            <span class="block sm:inline"><%= error %></span>
        </div>
    <% } %>

    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl font-bold text-gray-800">Danh sách Sản phẩm</h1>
        
        <form action="/" method="GET" class="flex w-full md:w-auto">
            <input type="text" name="q" value="<%= locals.searchQuery || '' %>" placeholder="Tìm kiếm theo tên..." 
                class="border border-gray-300 rounded-l-md px-4 py-2 w-full md:w-64 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-r-md hover:bg-blue-700 transition">
                <i class="fas fa-search"></i>
            </button>
            <% if (locals.searchQuery) { %>
                <a href="/" class="ml-2 bg-gray-200 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-300 transition flex items-center">
                    Xóa
                </a>
            <% } %>
        </form>
    </div>

    <% if (products.length === 0) { %>
        <div class="text-center py-12 text-gray-500">
            <i class="fas fa-box-open text-4xl mb-3"></i>
            <p class="text-lg">Không có sản phẩm nào.</p>
            <% if (locals.searchQuery) { %>
                <p class="text-sm mt-2">Không tìm thấy kết quả cho "<%= searchQuery %>"</p>
            <% } %>
        </div>
    <% } else { %>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200 text-gray-600 uppercase text-sm">
                        <th class="py-3 px-4 font-semibold">Hình ảnh</th>
                        <th class="py-3 px-4 font-semibold">Mã SP</th>
                        <th class="py-3 px-4 font-semibold">Tên sản phẩm</th>
                        <th class="py-3 px-4 font-semibold">Giá</th>
                        <th class="py-3 px-4 font-semibold">Số lượng</th>
                        <th class="py-3 px-4 font-semibold text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% products.forEach(product => { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="py-3 px-4">
                                <% if (product.image) { %>
                                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-16 h-16 object-cover rounded-md border" referrerpolicy="no-referrer">
                                <% } else { %>
                                    <img src="https://placehold.co/150x150?text=No+Image" alt="No image" class="w-16 h-16 object-cover rounded-md border text-gray-400">
                                <% } %>
                            </td>
                            <td class="py-3 px-4 font-mono text-sm text-gray-600"><%= product.ID %></td>
                            <td class="py-3 px-4 font-medium text-gray-800"><%= product.name %></td>
                            <td class="py-3 px-4 text-blue-600 font-semibold"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.price) %></td>
                            <td class="py-3 px-4">
                                <span class="px-2 py-1 rounded-full text-xs font-medium <%= product.quantity > 0 ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                    <%= product.quantity %>
                                </span>
                            </td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex justify-center gap-2">
                                    <a href="/edit/<%= product.ID %>" class="text-blue-500 hover:text-blue-700 bg-blue-50 hover:bg-blue-100 p-2 rounded-md transition" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form action="/delete/<%= product.ID %>?_method=DELETE" method="POST" class="inline" data-name="<%= product.name %>" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm \'' + this.getAttribute('data-name') + '\' không?');">
                                        <button type="submit" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-md transition" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
        <div class="flex justify-center mt-6 gap-2">
            <% if (hasPrevPage) { %>
                <a href="/?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>" class="px-4 py-2 border border-gray-300 rounded-md hover:bg-gray-50 text-gray-600 transition">Trang trước</a>
            <% } else { %>
                <button disabled class="px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-400 cursor-not-allowed">Trang trước</button>
            <% } %>

            <div class="flex items-center gap-1 mx-2">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="/?page=<%= i %><%= searchQuery ? '&q=' + searchQuery : '' %>" 
                       class="px-3 py-1 rounded-md <%= currentPage === i ? 'bg-blue-600 text-white' : 'hover:bg-gray-100 text-gray-700' %> transition">
                        <%= i %>
                    </a>
                <% } %>
            </div>

            <% if (hasNextPage) { %>
                <a href="/?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>" class="px-4 py-2 border border-gray-300 rounded-md hover:bg-gray-50 text-gray-600 transition">Trang sau</a>
            <% } else { %>
                <button disabled class="px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-400 cursor-not-allowed">Trang sau</button>
            <% } %>
        </div>
        <% } %>
    <% } %>
</div>
