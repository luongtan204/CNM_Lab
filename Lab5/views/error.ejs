<div class="max-w-2xl mx-auto bg-white rounded-lg shadow-md p-8 text-center">
    <div class="text-red-500 mb-4">
        <i class="fas fa-exclamation-triangle text-6xl"></i>
    </div>
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Đã xảy ra lỗi</h1>
    <p class="text-gray-600 mb-6"><%= message %></p>
    
    <% if (error && process.env.NODE_ENV !== 'production') { %>
        <div class="bg-gray-100 p-4 rounded text-left overflow-x-auto mb-6">
            <pre class="text-xs text-gray-700 font-mono"><%= error.stack || error.message || JSON.stringify(error) %></pre>
        </div>
    <% } %>
    
    <a href="/" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition font-medium">
        <i class="fas fa-home mr-2"></i> Về trang chủ
    </a>
</div>
