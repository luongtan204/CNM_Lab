<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Sản phẩm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">
    <nav class="bg-blue-600 text-white shadow-md">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <a href="/" class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-box-open"></i> Quản lý Sản phẩm
            </a>
            <div>
                <a href="/add" class="bg-white text-blue-600 px-4 py-2 rounded-md font-medium hover:bg-blue-50 transition">
                    <i class="fas fa-plus mr-1"></i> Thêm Sản phẩm
                </a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-4 py-8 flex-grow">
        <%- body %>
    </main>

    <footer class="bg-white border-t mt-auto py-4 text-center text-gray-500 text-sm">
        &copy; <%= new Date().getFullYear() %> Quản lý Sản phẩm. Node.js + EJS + DynamoDB + S3.
    </footer>
</body>
</html>
