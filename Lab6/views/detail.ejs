<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
<div class="max-w-lg w-full bg-white rounded-xl shadow-lg overflow-hidden">
    <% if(product.url_image) { %>
        <div class="h-64 w-full bg-gray-50 border-b">
            <img src="<%= product.url_image %>" class="w-full h-full object-contain" alt="Product Image">
        </div>
    <% } else { %>
        <div class="h-64 w-full bg-gray-200 flex justify-center items-center border-b">
            <span class="text-gray-500 text-lg">No Image Available</span>
        </div>
    <% } %>
    <div class="p-8 text-center">
        <h3 class="text-3xl font-bold text-gray-800 mb-2"><%= product.name %></h3>
        <p class="text-4xl font-extrabold text-green-600 mb-4">$<%= product.price %></p>
        <p class="text-gray-600 text-lg mb-8"><strong>Units in stock:</strong> <span class="text-gray-900 font-medium"><%= product.unit_in_stock %></span></p>
        <div class="flex justify-center space-x-4">
            <a href="/" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-6 rounded transition duration-200">Back to List</a>
            <a href="/edit/<%= product.id %>" class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-2 px-6 rounded transition duration-200">Edit Product</a>
        </div>
    </div>
</div>
</body>
</html>
