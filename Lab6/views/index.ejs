<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product List</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-8">
<div class="max-w-6xl mx-auto bg-white p-6 rounded-lg shadow-md">
    <h2 class="text-3xl font-bold mb-6 text-gray-800">Product List</h2>
    
    <% if(success_msg && success_msg.length > 0){ %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline"><%= success_msg %></span>
        </div>
    <% } %>
    <% if(error_msg && error_msg.length > 0){ %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline"><%= error_msg %></span>
        </div>
    <% } %>

    <div class="flex justify-between items-center mb-6">
        <a href="/add" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow">Add Product</a>
        <form action="/" method="GET" class="flex w-1/2">
            <input type="text" name="search" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline mr-2" placeholder="Search by name" value="<%= search || '' %>">
            <button class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded shadow focus:outline-none focus:shadow-outline" type="submit">Search</button>
        </form>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full bg-white border border-gray-200">
            <thead class="bg-gray-800 text-white">
                <tr>
                    <th class="py-3 px-4 uppercase font-semibold text-sm text-left">Image</th>
                    <th class="py-3 px-4 uppercase font-semibold text-sm text-left">Name</th>
                    <th class="py-3 px-4 uppercase font-semibold text-sm text-left">Price</th>
                    <th class="py-3 px-4 uppercase font-semibold text-sm text-left">In Stock</th>
                    <th class="py-3 px-4 uppercase font-semibold text-sm text-left">Actions</th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                <% if(products.length > 0) { %>
                    <% products.forEach((product, index) => { %>
                        <tr class="<%= index % 2 === 0 ? 'bg-gray-50' : 'bg-white' %> border-b border-gray-200 hover:bg-gray-100">
                            <td class="py-3 px-4">
                                <% if(product.url_image) { %>
                                    <div class="w-20 h-20 rounded overflow-hidden">
                                        <img src="<%= product.url_image %>" alt="image" class="w-full h-full object-cover">
                                    </div>
                                <% } else { %>
                                    <span class="text-gray-500 italic">No Image</span>
                                <% } %>
                            </td>
                            <td class="py-3 px-4 font-medium"><%= product.name %></td>
                            <td class="py-3 px-4">$<%= product.price %></td>
                            <td class="py-3 px-4"><%= product.unit_in_stock %></td>
                            <td class="py-3 px-4">
                                <div class="flex space-x-2">
                                    <a href="/detail/<%= product.id %>" class="bg-teal-500 hover:bg-teal-600 text-white text-sm font-bold py-1 px-3 rounded">View</a>
                                    <a href="/edit/<%= product.id %>" class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-bold py-1 px-3 rounded">Edit</a>
                                    <form action="/delete/<%= product.id %>" method="POST" class="inline" onsubmit="return confirm('Are you sure?');">
                                        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white text-sm font-bold py-1 px-3 rounded">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="py-4 px-4 text-center text-gray-500">No products found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
</body>
</html>
