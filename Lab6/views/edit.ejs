<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
<div class="max-w-xl w-full">
    <h2 class="text-3xl font-bold text-gray-800 mb-6 text-center">Edit Product</h2>
    
    <% if(error_msg && error_msg.length > 0){ %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline"><%= error_msg %></span>
        </div>
    <% } %>

    <div class="bg-white rounded-xl shadow-lg border border-gray-200">
        <div class="p-8">
            <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                <div>
                    <label class="block text-gray-700 text-sm font-bold mb-2">Product Name</label>
                    <input type="text" name="name" class="shadow appearance-none border rounded w-full py-3 px-4 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent" value="<%= product.name %>" required>
                </div>
                <div class="flex flex-col md:flex-row gap-6">
                    <div class="w-full md:w-1/2">
                        <label class="block text-gray-700 text-sm font-bold mb-2">Price ($)</label>
                        <input type="number" step="0.01" name="price" class="shadow appearance-none border rounded w-full py-3 px-4 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent" value="<%= product.price %>" required>
                    </div>
                    <div class="w-full md:w-1/2">
                        <label class="block text-gray-700 text-sm font-bold mb-2">Units in Stock</label>
                        <input type="number" name="unit_in_stock" class="shadow appearance-none border rounded w-full py-3 px-4 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent" value="<%= product.unit_in_stock %>" required>
                    </div>
                </div>
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">Current Image</label>
                        <div class="flex items-center space-x-4">
                            <% if(product.url_image) { %>
                                <div class="w-24 h-24 rounded border border-gray-300 overflow-hidden bg-gray-50">
                                    <img src="<%= product.url_image %>" class="w-full h-full object-cover" alt="Current Image">
                                </div>
                            <% } else { %>
                                <span class="text-gray-500 italic">None</span>
                            <% } %>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">Upload New Image (Leaves unchanged if empty)</label>
                        <input type="file" name="image" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-yellow-50 file:text-yellow-700 hover:file:bg-yellow-100 border border-gray-300 rounded cursor-pointer" accept="image/png, image/jpeg, image/jpg">
                    </div>
                </div>
                <div class="flex justify-between items-center pt-4">
                    <a href="/" class="text-gray-600 hover:text-gray-900 font-medium py-2 px-4 rounded border border-gray-300 hover:bg-gray-50 transition duration-150 ease-in-out">Cancel</a>
                    <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-2 px-8 rounded shadow-md focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-opacity-50 transition duration-150 ease-in-out">Update Product</button>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>
