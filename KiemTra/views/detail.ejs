<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chi tiet Ticket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/basic.css" rel="stylesheet" />
</head>

<body>
    <div class="container py-4" style="max-width: 700px;">
        <div class="mb-3">
            <h1>Chi tiet ve su kien</h1>
            <a href="/tickets" class="btn btn-secondary">Quay lai</a>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-8">
                        <p><strong>Ticket ID:</strong> <br/><small><%= ticket.ticketId %></small></p>
                        <p><strong>Ten su kien:</strong> <br/>
                            <%= ticket.eventName %>
                        </p>
                        <p><strong>Nguoi so huu:</strong> <br/>
                            <%= ticket.holderName %>
                        </p>
                        <p><strong>Category:</strong> <br/>
                            <%= ticket.category %>
                        </p>
                        <p><strong>So luong:</strong> <br/>
                            <%= ticket.quantity %>
                        </p>
                        <p><strong>Gia moi ve:</strong> <br/>
                            <%= Number(ticket.pricePerTicket).toLocaleString('vi-VN') %>
                        </p>
                        <p><strong>Ngay su kien:</strong> <br/>
                            <%= ticket.eventDate %>
                        </p>
                        <p><strong>Trang thai:</strong> <br/><span class="badge bg-info"><%= ticket.status %></span></p>
                        <p><strong>Tong tien:</strong> <br/>
                            <%= Number(ticket.totalAmount).toLocaleString('vi-VN') %>
                        </p>
                        <p><strong>Sau khi giam:</strong> <br/>
                            <%= Number(ticket.finalAmount).toLocaleString('vi-VN') %>
                        </p>

                        <% const discounted = Number(ticket.finalAmount) < Number(ticket.totalAmount); %>
                            <p>
                                <span class="badge <%= discounted ? 'bg-success' : 'bg-secondary' %>">
                  <%= discounted ? 'Co giam gia' : 'Khong giam gia' %>
                </span>
                            </p>
                    </div>

                    <div class="col-md-4">
                        <% if (ticket.imageUrl) { %>
                            <img src="<%= ticket.imageUrl %>" class="img-fluid ticket-image" alt="ticket-image" />
                            <% } else { %>
                                <div class="p-4 bg-light border text-center">Khong co anh</div>
                                <% } %>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a href="/tickets/<%= ticket.ticketId %>/edit" class="btn btn-warning">Sua</a>
                    <form action="/tickets/<%= ticket.ticketId %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Ban chac chan muon xoa?')">
                        <button class="btn btn-danger" type="submit">Xoa</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>

</html>