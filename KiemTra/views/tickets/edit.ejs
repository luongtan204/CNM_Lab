<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sua Event Ticket</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Cap nhat ve su kien</h1>
        <a href="/tickets" class="btn btn-outline-secondary">Quay lai</a>
      </div>

      <% if (errors.length) { %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% errors.forEach(function(err) { %>
              <li><%= err %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="card shadow-sm">
        <div class="card-body">
          <form action="/tickets/<%= ticket.ticketId %>/edit" method="POST" enctype="multipart/form-data" class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Ten su kien</label>
              <input type="text" class="form-control" name="eventName" value="<%= ticket.eventName %>" required />
            </div>

            <div class="col-md-6">
              <label class="form-label">Ten nguoi so huu</label>
              <input type="text" class="form-control" name="holderName" value="<%= ticket.holderName %>" required />
            </div>

            <div class="col-md-4">
              <label class="form-label">Category</label>
              <select class="form-select" name="category" required>
                <option value="Standard" <%= ticket.category === 'Standard' ? 'selected' : '' %>>Standard</option>
                <option value="VIP" <%= ticket.category === 'VIP' ? 'selected' : '' %>>VIP</option>
                <option value="VVIP" <%= ticket.category === 'VVIP' ? 'selected' : '' %>>VVIP</option>
              </select>
            </div>

            <div class="col-md-4">
              <label class="form-label">So luong</label>
              <input type="number" min="1" class="form-control" name="quantity" value="<%= ticket.quantity %>" required />
            </div>

            <div class="col-md-4">
              <label class="form-label">Gia moi ve</label>
              <input type="number" min="1" class="form-control" name="pricePerTicket" value="<%= ticket.pricePerTicket %>" required />
            </div>

            <div class="col-md-6">
              <label class="form-label">Ngay su kien</label>
              <input type="date" class="form-control" name="eventDate" value="<%= ticket.eventDate %>" required />
            </div>

            <div class="col-md-6">
              <label class="form-label">Trang thai</label>
              <select class="form-select" name="status" required>
                <option value="Upcoming" <%= ticket.status === 'Upcoming' ? 'selected' : '' %>>Upcoming</option>
                <option value="Sold" <%= ticket.status === 'Sold' ? 'selected' : '' %>>Sold</option>
                <option value="Cancelled" <%= ticket.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label">Anh moi (de trong neu khong doi)</label>
              <input type="file" class="form-control" name="image" accept="image/*" />
            </div>

            <% if (ticket.imageUrl) { %>
              <div class="col-12">
                <p class="mb-1">Anh hien tai:</p>
                <img src="<%= ticket.imageUrl %>" alt="ticket-image" style="max-width: 220px; border-radius: 8px;" />
              </div>
            <% } %>

            <div class="col-12">
              <button type="submit" class="btn btn-primary">Cap nhat ticket</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>
