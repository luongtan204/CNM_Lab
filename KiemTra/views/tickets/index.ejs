<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Event Tickets - Danh sach</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/basic.css" rel="stylesheet" />
</head>

<body>
    <div class="navbar-top">
        <h1>Event Tickets Manager</h1>
    </div>

    <div class="main-wrapper">
        <div class="sidebar">
            <a href="/tickets" class="active">Danh sach</a>
            <a href="/tickets/add">Them ve</a>
        </div>

        <div class="main-content">
            <% if (message) { %>
                <div class="alert alert-<%= messageType %>">
                    <%= message %>
                </div>
                <% } %>

                    <div class="page-header">
                        <h2>Quan ly Event Tickets</h2>
                        <a href="/tickets/add" class="btn-add">+ Them ve moi</a>
                    </div>

                    <div class="search-filter">
                        <form method="GET" action="/tickets">
                            <div class="row">
                                <div class="col-md-6 col-12">
                                    <input class="form-control" type="text" name="q" placeholder="Tim theo ten su kien hoac nguoi so huu..." value="<%= query %>" />
                                </div>
                                <div class="col-md-4 col-12">
                                    <select class="form-select" name="status">
                  <option value="">Tat ca trang thai</option>
                  <option value="Upcoming" <%= status === 'Upcoming' ? 'selected' : '' %>>Upcoming</option>
                  <option value="Sold" <%= status === 'Sold' ? 'selected' : '' %>>Sold</option>
                  <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                                </div>
                                <div class="col-md-2 col-12">
                                    <button class="btn btn-primary w-100" type="submit">Tim</button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="ticket-grid">
                        <% if (!tickets.length) { %>
                            <div style="grid-column: 1 / -1; text-align: center; padding: 2rem; color: #999;">
                                <p style="font-size: 1.2rem;">Chua co du lieu</p>
                            </div>
                            <% } %>

                                <% tickets.forEach(function(ticket) { %>
                                    <div class="ticket-card">
                                        <div class="ticket-card-header">
                                            <h3>
                                                <%= ticket.eventName %>
                                            </h3>
                                            <div class="ticket-card-id">ID:
                                                <%= ticket.ticketId %>
                                            </div>
                                        </div>
                                        <div class="ticket-card-body">
                                            <div class="ticket-info">
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">Nguoi so huu:</span>
                                                    <span class="ticket-info-value"><%= ticket.holderName %></span>
                                                </div>
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">Loai:</span>
                                                    <span class="ticket-info-value"><%= ticket.category %></span>
                                                </div>
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">So luong:</span>
                                                    <span class="ticket-info-value"><%= ticket.quantity %></span>
                                                </div>
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">Gia/ve:</span>
                                                    <span class="ticket-info-value"><%= Number(ticket.pricePerTicket).toLocaleString('vi-VN') %></span>
                                                </div>
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">Tong:</span>
                                                    <span class="ticket-info-value"><%= Number(ticket.totalAmount).toLocaleString('vi-VN') %></span>
                                                </div>
                                                <div class="ticket-info-item">
                                                    <span class="ticket-info-label">Sau giam:</span>
                                                    <span class="ticket-info-value"><strong><%= Number(ticket.finalAmount).toLocaleString('vi-VN') %></strong></span>
                                                </div>
                                            </div>

                                            <div class="ticket-badges">
                                                <span class="badge bg-info"><%= ticket.status %></span>
                                                <% const discounted = Number(ticket.finalAmount) < Number(ticket.totalAmount); %>
                                                    <span class="badge <%= discounted ? 'bg-success' : 'bg-secondary' %>">
                    <%= discounted ? 'Co giam' : 'Khong giam' %>
                  </span>
                                            </div>

                                            <div class="ticket-actions">
                                                <a class="btn btn-primary" href="/tickets/<%= ticket.ticketId %>">Chi tiet</a>
                                                <a class="btn btn-warning" href="/tickets/<%= ticket.ticketId %>/edit">Sua</a>
                                                <form action="/tickets/<%= ticket.ticketId %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Ban chac chan muon xoa?')">
                                                    <button class="btn btn-danger" type="submit">Xoa</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                    </div>
        </div>
    </div>
</body>

</html>