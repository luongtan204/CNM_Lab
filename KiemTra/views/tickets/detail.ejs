<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chi tiet Ticket</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Chi tiet ve su kien</h1>
        <a href="/tickets" class="btn btn-outline-secondary">Quay lai</a>
      </div>

      <div class="card shadow-sm">
        <div class="card-body row g-3">
          <div class="col-md-8">
            <p><strong>Ticket ID:</strong> <%= ticket.ticketId %></p>
            <p><strong>Ten su kien:</strong> <%= ticket.eventName %></p>
            <p><strong>Nguoi so huu:</strong> <%= ticket.holderName %></p>
            <p><strong>Category:</strong> <%= ticket.category %></p>
            <p><strong>So luong:</strong> <%= ticket.quantity %></p>
            <p><strong>Gia moi ve:</strong> <%= Number(ticket.pricePerTicket).toLocaleString('vi-VN') %></p>
            <p><strong>Ngay su kien:</strong> <%= ticket.eventDate %></p>
            <p><strong>Trang thai:</strong> <span class="badge text-bg-info"><%= ticket.status %></span></p>
            <p><strong>Created at:</strong> <%= ticket.createdAt %></p>
            <p><strong>Total amount:</strong> <%= Number(ticket.totalAmount).toLocaleString('vi-VN') %></p>
            <p><strong>Final amount:</strong> <%= Number(ticket.finalAmount).toLocaleString('vi-VN') %></p>

            <% const discounted = Number(ticket.finalAmount) < Number(ticket.totalAmount); %>
            <% if (discounted) { %>
              <span class="badge text-bg-success">Duoc giam gia</span>
            <% } else { %>
              <span class="badge text-bg-secondary">Khong giam gia</span>
            <% } %>
          </div>

          <div class="col-md-4">
            <% if (ticket.imageUrl) { %>
              <img src="<%= ticket.imageUrl %>" class="img-fluid rounded" alt="ticket image" />
            <% } else { %>
              <div class="p-4 bg-secondary-subtle rounded text-center">Khong co anh</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
