<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Them Event Ticket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/basic.css" rel="stylesheet" />
</head>

<body>
    <div class="navbar-top">
        <h1>Event Tickets Manager</h1>
    </div>

    <div class="main-wrapper">
        <div class="sidebar">
            <a href="/tickets">Danh sach</a>
            <a href="/tickets/add" class="active">Them ve</a>
        </div>

        <div class="main-content">
            <div class="detail-container">
                <div class="page-header mb-4">
                    <h2>Them ve su kien moi</h2>
                    <a href="/tickets" class="btn btn-secondary">Quay lai</a>
                </div>

                <% if (errors.length) { %>
                    <div class="alert alert-danger">
                        <strong>Loi:</strong>
                        <ul class="mb-0">
                            <% errors.forEach(function(err) { %>
                                <li>
                                    <%= err %>
                                </li>
                                <% }) %>
                        </ul>
                    </div>
                    <% } %>

                        <div class="detail-card">
                            <div class="detail-header">
                                <h2>Nhap thong tin ve</h2>
                            </div>
                            <div class="detail-body">
                                <form action="/tickets/add" method="POST" enctype="multipart/form-data">
                                    <div class="row">
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label">Ten su kien</label>
                                            <input type="text" class="form-control" name="eventName" value="<%= ticket.eventName %>" required />
                                        </div>
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label">Ten nguoi so huu</label>
                                            <input type="text" class="form-control" name="holderName" value="<%= ticket.holderName %>" required />
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-4">
                                            <label class="form-label">Loai ve</label>
                                            <select class="form-select" name="category" required>
                      <option value="">-- Chon loai --</option>
                      <option value="Standard" <%= ticket.category === 'Standard' ? 'selected' : '' %>>Standard</option>
                      <option value="VIP" <%= ticket.category === 'VIP' ? 'selected' : '' %>>VIP</option>
                      <option value="VVIP" <%= ticket.category === 'VVIP' ? 'selected' : '' %>>VVIP</option>
                    </select>
                                        </div>
                                        <div class="col-md-4 mb-4">
                                            <label class="form-label">So luong ve</label>
                                            <input type="number" min="1" class="form-control" name="quantity" value="<%= ticket.quantity %>" required />
                                        </div>
                                        <div class="col-md-4 mb-4">
                                            <label class="form-label">Gia moi ve (VND)</label>
                                            <input type="number" min="1" class="form-control" name="pricePerTicket" value="<%= ticket.pricePerTicket %>" required />
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label">Ngay to chuc su kien</label>
                                            <input type="date" class="form-control" name="eventDate" value="<%= ticket.eventDate %>" required />
                                        </div>
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label">Trang thai</label>
                                            <select class="form-select" name="status" required>
                      <option value="">-- Chon trang thai --</option>
                      <option value="Upcoming" <%= ticket.status === 'Upcoming' ? 'selected' : '' %>>Upcoming</option>
                      <option value="Sold" <%= ticket.status === 'Sold' ? 'selected' : '' %>>Sold</option>
                      <option value="Cancelled" <%= ticket.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label">Anh minh hoa</label>
                                        <input type="file" class="form-control" name="image" accept="image/*" />
                                        <small class="text-muted">Dinh dang: JPG, PNG (Tuy chon)</small>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-primary btn-lg">Luu ticket</button>
                                        <a href="/tickets" class="btn btn-secondary btn-lg">Huy</a>
                                    </div>
                                </form>
                            </div>
                        </div>
            </div>
        </div>
    </div>
</body>

</html>